{
  "name": "sam-postgres-mtls-explorer",
  "displayName": "Sam's PostgreSQL mTLS Explorer",
  "description": "Connect to PostgreSQL databases using mTLS (Teleport/Infrastructure Access Control) and browse database objects visually",
  "version": "0.1.1",
  "publisher": "samujjal",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/samujjalm/vscode-postgres-plugin"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "postgresql",
    "postgres",
    "mtls",
    "teleport",
    "database",
    "sql"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "languages": [
      {
        "id": "psql",
        "aliases": ["PostgreSQL", "psql"],
        "extensions": [".psql"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "psql",
        "scopeName": "source.psql",
        "path": "./syntaxes/psql.tmLanguage.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "postgres-mtls-explorer",
          "title": "PostgreSQL mTLS Explorer",
          "icon": "media/database.svg"
        }
      ]
    },
    "views": {
      "postgres-mtls-explorer": [
        {
          "id": "postgresConnections",
          "name": "Connections"
        },
        {
          "id": "postgresDatabaseObjects",
          "name": "Database Objects"
        }
      ],
      "panel": [
        {
          "type": "webview",
          "id": "postgresQueryResults",
          "name": "PG Results"
        }
      ]
    },
    "commands": [
      {
        "command": "postgres-mtls.addConnection",
        "title": "Add Connection (Manual)",
        "category": "PostgreSQL mTLS",
        "icon": "$(add)"
      },
      {
        "command": "postgres-mtls.addFromTeleport",
        "title": "Add from Teleport",
        "category": "PostgreSQL mTLS",
        "icon": "$(cloud-download)"
      },
      {
        "command": "postgres-mtls.selectConnection",
        "title": "Change DB Connection",
        "category": "PostgreSQL mTLS",
        "icon": "$(database)"
      },
      {
        "command": "postgres-mtls.editConnection",
        "title": "Edit Connection",
        "category": "PostgreSQL mTLS",
        "icon": "$(edit)"
      },
      {
        "command": "postgres-mtls.deleteConnection",
        "title": "Delete Connection",
        "category": "PostgreSQL mTLS",
        "icon": "$(trash)"
      },
      {
        "command": "postgres-mtls.connect",
        "title": "Connect",
        "category": "PostgreSQL mTLS",
        "icon": "$(plug)"
      },
      {
        "command": "postgres-mtls.disconnect",
        "title": "Disconnect",
        "category": "PostgreSQL mTLS",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "postgres-mtls.refreshObjects",
        "title": "Refresh Database Objects",
        "category": "PostgreSQL mTLS",
        "icon": "$(refresh)"
      },
      {
        "command": "postgres-mtls.newQuery",
        "title": "New SQL Query",
        "category": "PostgreSQL mTLS",
        "icon": "$(new-file)"
      },
      {
        "command": "postgres-mtls.runQuery",
        "title": "Run Query",
        "category": "PostgreSQL mTLS",
        "icon": "$(play)"
      },
      {
        "command": "postgres-mtls.viewTableData",
        "title": "View Table Data (Top 100)",
        "category": "PostgreSQL mTLS",
        "icon": "$(table)"
      },
      {
        "command": "postgres-mtls.viewTableStructure",
        "title": "View Table Structure",
        "category": "PostgreSQL mTLS"
      },
      {
        "command": "postgres-mtls.exportCsv",
        "title": "Export Results as CSV",
        "category": "PostgreSQL mTLS",
        "icon": "$(export)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "postgres-mtls.addFromTeleport",
          "when": "view == postgresConnections",
          "group": "navigation"
        },
        {
          "command": "postgres-mtls.addConnection",
          "when": "view == postgresConnections",
          "group": "navigation"
        },
        {
          "command": "postgres-mtls.refreshObjects",
          "when": "view == postgresDatabaseObjects",
          "group": "navigation"
        },
        {
          "command": "postgres-mtls.newQuery",
          "when": "view == postgresDatabaseObjects",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "postgres-mtls.connect",
          "when": "view == postgresConnections && viewItem == disconnected",
          "group": "inline"
        },
        {
          "command": "postgres-mtls.disconnect",
          "when": "view == postgresConnections && viewItem == connected",
          "group": "inline"
        },
        {
          "command": "postgres-mtls.editConnection",
          "when": "view == postgresConnections && viewItem =~ /connected|disconnected/",
          "group": "context@1"
        },
        {
          "command": "postgres-mtls.deleteConnection",
          "when": "view == postgresConnections && viewItem =~ /connected|disconnected/",
          "group": "context@2"
        },
        {
          "command": "postgres-mtls.viewTableData",
          "when": "view == postgresDatabaseObjects && viewItem == table",
          "group": "inline"
        },
        {
          "command": "postgres-mtls.viewTableStructure",
          "when": "view == postgresDatabaseObjects && viewItem == table"
        }
      ],
      "editor/title": [
        {
          "command": "postgres-mtls.runQuery",
          "when": "resourceLangId == psql",
          "group": "navigation"
        },
        {
          "command": "postgres-mtls.selectConnection",
          "when": "resourceLangId == psql",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "postgres-mtls.selectConnection",
          "when": "resourceLangId == psql",
          "group": "z_postgres@1"
        },
        {
          "command": "postgres-mtls.runQuery",
          "when": "resourceLangId == psql",
          "group": "z_postgres@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "postgres-mtls.runQuery",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && resourceLangId == psql"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "[*]": {
          "textMateRules": [
            {
              "scope": "keyword.other.dml.psql",
              "settings": { "foreground": "#C586C0", "fontStyle": "bold" }
            },
            {
              "scope": "keyword.other.dml.secondary.psql",
              "settings": { "foreground": "#C586C0" }
            },
            {
              "scope": "keyword.other.ddl.create.psql",
              "settings": { "foreground": "#C586C0", "fontStyle": "bold" }
            },
            {
              "scope": "keyword.other.ddl.object.psql",
              "settings": { "foreground": "#C586C0" }
            },
            {
              "scope": "keyword.other.ddl.constraint.psql",
              "settings": { "foreground": "#D4A0D0" }
            },
            {
              "scope": "keyword.other.ddl.index.psql",
              "settings": { "foreground": "#D4A0D0" }
            },
            {
              "scope": "keyword.other.clause.psql",
              "settings": { "foreground": "#569CD6", "fontStyle": "bold" }
            },
            {
              "scope": "keyword.other.order.psql",
              "settings": { "foreground": "#569CD6" }
            },
            {
              "scope": "keyword.other.set.psql",
              "settings": { "foreground": "#569CD6", "fontStyle": "bold" }
            },
            {
              "scope": "keyword.other.cte.psql",
              "settings": { "foreground": "#569CD6", "fontStyle": "bold" }
            },
            {
              "scope": "keyword.other.subquery.psql",
              "settings": { "foreground": "#569CD6" }
            },
            {
              "scope": "keyword.operator.logical.psql",
              "settings": { "foreground": "#569CD6" }
            },
            {
              "scope": "keyword.other.join.psql",
              "settings": { "foreground": "#4EC9B0", "fontStyle": "bold" }
            },
            {
              "scope": "keyword.control.psql",
              "settings": { "foreground": "#C586C0" }
            },
            {
              "scope": "keyword.other.transaction.psql",
              "settings": { "foreground": "#C586C0", "fontStyle": "italic" }
            },
            {
              "scope": "keyword.other.window.psql",
              "settings": { "foreground": "#4EC9B0" }
            },
            {
              "scope": "keyword.other.psql",
              "settings": { "foreground": "#C586C0" }
            },
            {
              "scope": "storage.type.psql",
              "settings": { "foreground": "#4EC9B0" }
            },
            {
              "scope": "storage.type.array.psql",
              "settings": { "foreground": "#4EC9B0" }
            },
            {
              "scope": [
                "support.function.string.psql",
                "support.function.datetime.psql",
                "support.function.math.psql",
                "support.function.json.psql",
                "support.function.array.psql",
                "support.function.misc.psql"
              ],
              "settings": { "foreground": "#DCDCAA" }
            },
            {
              "scope": "support.function.aggregate.psql",
              "settings": { "foreground": "#DCDCAA", "fontStyle": "bold" }
            },
            {
              "scope": "support.function.cast.psql",
              "settings": { "foreground": "#DCDCAA" }
            },
            {
              "scope": "constant.language.boolean.psql",
              "settings": { "foreground": "#569CD6" }
            },
            {
              "scope": "constant.language.null.psql",
              "settings": { "foreground": "#569CD6", "fontStyle": "italic" }
            },
            {
              "scope": [
                "constant.numeric.float.psql",
                "constant.numeric.integer.psql",
                "constant.numeric.hex.psql"
              ],
              "settings": { "foreground": "#B5CEA8" }
            },
            {
              "scope": "string.quoted.single.psql",
              "settings": { "foreground": "#CE9178" }
            },
            {
              "scope": "string.unquoted.dollar.psql",
              "settings": { "foreground": "#CE9178" }
            },
            {
              "scope": "comment.line.double-dash.psql",
              "settings": { "foreground": "#6A9955", "fontStyle": "italic" }
            },
            {
              "scope": "comment.block.psql",
              "settings": { "foreground": "#6A9955", "fontStyle": "italic" }
            },
            {
              "scope": "entity.name.schema.psql",
              "settings": { "foreground": "#9CDCFE" }
            },
            {
              "scope": "entity.name.table.psql",
              "settings": { "foreground": "#9CDCFE" }
            },
            {
              "scope": "variable.parameter.psql",
              "settings": { "foreground": "#9CDCFE" }
            },
            {
              "scope": "variable.other.psql",
              "settings": { "foreground": "#9CDCFE" }
            },
            {
              "scope": [
                "keyword.operator.comparison.psql",
                "keyword.operator.arithmetic.psql",
                "keyword.operator.concatenation.psql",
                "keyword.operator.json.psql",
                "keyword.operator.range.psql"
              ],
              "settings": { "foreground": "#D4D4D4" }
            }
          ]
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
